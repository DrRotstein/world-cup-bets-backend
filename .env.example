# Environment variables for world-cup-bets-backend
# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/world_cup_bets?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"  # optional — defaults to 7d if omitted

# Google OAuth (ID token verification only — no client secret needed)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Football Data API (football-data.org v4)
FOOTBALL_DATA_API_KEY="your-football-data-api-key"
